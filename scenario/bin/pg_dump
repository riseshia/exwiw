#!/usr/bin/env bash
# Local pg_dump shim that delegates to the postgres container in compose.yml.
#
# pg_dump enforces a strict major-version match with the server, but the dev
# DB runs postgres:17 in Docker while a contributor's host may ship pg_dump
# 14/16 (e.g. Homebrew). Reusing the container's binary lets everyone run
# `scenario/test_with_postgresql.sh` without installing pg17 system-wide.
#
# Activated via `mise.toml` (`_.path`) so this only shadows pg_dump inside
# this repository.
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/../.." && pwd)"

cd "${repo_root}"
exec docker compose exec -T -e "PGPASSWORD=${PGPASSWORD:-}" postgres pg_dump "$@"
